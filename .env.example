# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Tutor (Wren) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Code Execution ────────────────────────────────────────────
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-rapidapi-key

# ── Payments ──────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your-key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-key

# ── Video ─────────────────────────────────────────────────────
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# ── Email ─────────────────────────────────────────────────────
RESEND_API_KEY=re_your-key
EMAIL_FROM=hello@wikrena.com

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Redis Cache (Upstash) ──────────────────────────────────────────────────────
# Get these from https://console.upstash.com → Create Database → REST API
# Free tier: 10,000 requests/day — sufficient for development and early production
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Background Jobs ────────────────────────────────────────────────────────────
# Random secret string — used to authenticate Vercel Cron calls
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ── Site URL (required for email links and certificates) ──────────────────────
NEXT_PUBLIC_SITE_URL=https://academy.wikrena.com
